<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="promote-msadmin-to-admin" author="msfintech">
        <comment>Ensure the default msadmin user can access admin endpoints</comment>
        <update tableName="users">
            <column name="is_admin" valueBoolean="true"/>
            <where>username = 'msadmin'</where>
        </update>
        <rollback>
            <update tableName="users">
                <column name="is_admin" valueBoolean="false"/>
                <where>username = 'msadmin'</where>
            </update>
        </rollback>
    </changeSet>

</databaseChangeLog>
