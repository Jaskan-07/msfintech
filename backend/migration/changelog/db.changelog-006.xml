<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="rename-hashed-password-to-password" author="msfintech">
        <comment>Rename hashed_password to password for plain-text storage</comment>
        <renameColumn tableName="users" oldColumnName="hashed_password" newColumnName="password" columnDataType="VARCHAR(255)"/>
    </changeSet>

</databaseChangeLog>
