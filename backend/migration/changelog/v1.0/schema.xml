<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ================================================================== -->
    <!-- ROLES TABLE                                                        -->
    <!-- ================================================================== -->
    <changeSet id="001-ms_role" author="economic-dashboard">
        <comment>Create ms_role table</comment>

        <createTable tableName="ms_role">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="ms_role"/>
        </rollback>
    </changeSet>

    <!-- ================================================================== -->
    <!-- USERS TABLE                                                        -->
    <!-- ================================================================== -->
    <changeSet id="002-ms_user" author="economic-dashboard">
        <comment>Create ms_user table for authentication</comment>
        
        <createTable tableName="ms_user">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="hashed_password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(100)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="role_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_ms_user_ms_role" references="ms_role(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex tableName="ms_user" indexName="idx_ms_user_username">
            <column name="username"/>
        </createIndex>
        
        <createIndex tableName="ms_user" indexName="idx_ms_user_email">
            <column name="email"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="ms_user"/>
        </rollback>
    </changeSet>

    <changeSet id="003-ms_permission" author="economic-dashboard">
        <comment>Create ms_permission table for authorization</comment>

        <createTable tableName="ms_permission">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
             <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="ms_permission"/>
        </rollback>
    </changeSet>

    <changeSet id="004-ms_role_permission" author="economic-dashboard">
        <comment>Create ms_role_permission table for role-based permissions</comment>

        <createTable tableName="ms_role_permission">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>   
            <column name="role_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="permission_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>   
        </createTable>

        <addForeignKeyConstraint
            baseTableName="ms_role_permission"
            baseColumnNames="role_id"
            referencedTableName="ms_role"
            referencedColumnNames="id"
            constraintName="fk_ms_role_permission_role"/>

        <addForeignKeyConstraint
            baseTableName="ms_role_permission"
            baseColumnNames="permission_id"
            referencedTableName="ms_permission"
            referencedColumnNames="id"
            constraintName="fk_ms_role_permission_permission"/>
        
        <addUniqueConstraint 
            tableName="ms_role_permission" 
            columnNames="role_id, permission_id" 
            constraintName="uk_ms_role_permission_role_permission"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="ms_role_permission" constraintName="fk_ms_role_permission_role"/>
            <dropForeignKeyConstraint baseTableName="ms_role_permission" constraintName="fk_ms_role_permission_permission"/>
            <dropTable tableName="ms_role_permission"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
