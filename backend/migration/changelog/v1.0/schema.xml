<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ================================================================== -->
    <!-- ROLES TABLE                                                        -->
    <!-- ================================================================== -->
    <changeSet id="001-ms_roles" author="economic-dashboard">
        <comment>Create ms_roles table</comment>

        <createTable tableName="ms_roles">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="ms_roles"/>
        </rollback>
    </changeSet>

    <!-- ================================================================== -->
    <!-- USERS TABLE                                                        -->
    <!-- ================================================================== -->
    <changeSet id="002-ms_users" author="economic-dashboard">
        <comment>Create ms_users table for authentication</comment>
        
        <createTable tableName="ms_users">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="hashed_password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(100)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex tableName="ms_users" indexName="idx_ms_users_username">
            <column name="username"/>
        </createIndex>
        
        <createIndex tableName="ms_users" indexName="idx_ms_users_email">
            <column name="email"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="ms_users"/>
        </rollback>
    </changeSet>

    <changeSet id="003-add-role-id-to-ms_users" author="economic-dashboard">
        <comment>Add role_id to ms_users table</comment>

        <addColumn tableName="ms_users">
            <column name="role_id" type="INT"/>
        </addColumn>

        <addForeignKeyConstraint
            baseTableName="ms_users"
            baseColumnNames="role_id"
            referencedTableName="ms_roles"
            referencedColumnNames="id"
            constraintName="fk_ms_users_ms_roles"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="ms_users" constraintName="fk_ms_users_roles"/>
            <dropColumn tableName="ms_users" columnName="role_id"/>
        </rollback>
    </changeSet>

    <changeSet id="004-ms_permissions" author="economic-dashboard">
        <comment>Create ms_permissions table for authorization</comment>

        <createTable tableName="ms_permissions">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
             <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="ms_permissions"/>
        </rollback>
    </changeSet>

    <changeSet id="005-ms_role_permissions" author="economic-dashboard">
        <comment>Create ms_role_permissions table for role-based permissions</comment>

        <createTable tableName="ms_role_permissions">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>   
            <column name="role_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="permission_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>   
        </createTable>

        <addForeignKeyConstraint
            baseTableName="ms_role_permissions"
            baseColumnNames="role_id"
            referencedTableName="ms_roles"
            referencedColumnNames="id"
            constraintName="fk_ms_role_permissions_roles"/>

        <addForeignKeyConstraint
            baseTableName="ms_role_permissions"
            baseColumnNames="permission_id"
            referencedTableName="ms_permissions"
            referencedColumnNames="id"
            constraintName="fk_ms_role_permissions_permissions"/>
        
        <addUniqueConstraint 
            tableName="ms_role_permissions" 
            columnNames="role_id, permission_id" 
            constraintName="uk_ms_role_permissions_role_permission"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="ms_role_permissions" constraintName="fk_ms_role_permissions_roles"/>
            <dropForeignKeyConstraint baseTableName="ms_role_permissions" constraintName="fk_ms_role_permissions_permissions"/>
            <dropTable tableName="ms_role_permissions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
