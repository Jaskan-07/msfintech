<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ================================================================== -->
    <!-- SEED DEFAULT ROLES                                                 -->
    <!-- ================================================================== -->
    <changeSet id="004-seed-roles" author="economic-dashboard">
        <comment>Seed default roles</comment>

        <insert tableName="ms_roles">
            <column name="name" value="admin"/>
            <column name="description" value="Full access to ms_users and APIs"/>
        </insert>

        <insert tableName="ms_roles">
            <column name="name" value="analyst"/>
            <column name="description" value="Can view and work with dashboard data"/>
        </insert>

        <insert tableName="ms_roles">
            <column name="name" value="inactive"/>
            <column name="description" value="No active access"/>
        </insert>
    </changeSet>

    <!-- ================================================================== -->
    <!-- SEED DEFAULT ADMIN USER                                            -->
    <!-- ================================================================== -->
    <changeSet id="005-seed-admin" author="economic-dashboard">
        <comment>Seed default admin user (msadmin/all4one)</comment>
        <sqlFile
            path="postgres/seed-admin-user.sql"
            relativeToChangelogFile="true"
            splitStatements="false"/>
        <rollback>
            <delete tableName="ms_users">
                <where>username = 'msadmin'</where>
            </delete>
        </rollback>
    </changeSet>

    <changeSet id="006-assign-admin-role" author="economic-dashboard">
        <comment>Assign admin role to default admin user</comment>

        <sql>
            UPDATE ms_users
            SET role_id = (SELECT id FROM ms_roles WHERE name = 'admin')
            WHERE username = 'msadmin';
        </sql>
    </changeSet>

    <changeSet id="007-seed-permissions" author="economic-dashboard">
        <comment>Seed default permissions</comment>

        <insert tableName="ms_permissions">
            <column name="name" value="view_dashboard"/>
            <column name="description" value="Permission to view the dashboard"/>
        </insert>

        <insert tableName="ms_permissions">
            <column name="name" value="edit_dashboard"/>
            <column name="description" value="Permission to edit the dashboard"/>
        </insert>

        <insert tableName="ms_permissions">
            <column name="name" value="manage_users"/>
            <column name="description" value="Permission to manage users"/>
        </insert>

        <rollback>
            <delete tableName="ms_permissions">
                <where>name IN ('view_dashboard', 'edit_dashboard', 'manage_users')</where>
            </delete>
        </rollback>
    </changeSet>

    <changeSet id="008-seed-role-permissions" author="economic-dashboard">
        <comment>Seed default role permissions</comment>

        <sql>
            INSERT INTO ms_role_permissions (role_id, permission_id)
            VALUES  
            (
                (SELECT id FROM ms_roles WHERE name = 'admin'),
                (SELECT id FROM ms_permissions WHERE name = 'view_dashboard')
            ),
            (
                (SELECT id FROM ms_roles WHERE name = 'admin'),
                (SELECT id FROM ms_permissions WHERE name = 'edit_dashboard')
            ),
            (
                (SELECT id FROM ms_roles WHERE name = 'admin'),
                (SELECT id FROM ms_permissions WHERE name = 'manage_users')
            ),
            (
                (SELECT id FROM ms_roles WHERE name = 'analyst'),
                (SELECT id FROM ms_permissions WHERE name = 'view_dashboard')
            );
        </sql>

        <rollback>
            <sql>
                DELETE FROM ms_role_permissions
                WHERE role_id IN (
                    SELECT id FROM ms_roles WHERE name IN ('admin', 'analyst')
                )
                AND permission_id IN (
                    SELECT id FROM ms_permissions
                    WHERE name IN ('view_dashboard', 'edit_dashboard', 'manage_users')
                );
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
